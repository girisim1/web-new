# Sunucu Tarafı API Anahtarı (Production için - Vercel Panelinden eklenecek)
GEMINI_API_KEY=your_gemini_api_key_here

# Sadece Local (Geliştirici) Ortamı İçin (Tarayıcıda çalışması için VITE_ ekli)
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Supabase Kimlik Doğrulama ve Veritabanı Değişkenleri
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
